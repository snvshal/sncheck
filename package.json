{
  "name": "sncheck",
  "version": "1.0.0",
  "description": "A CLI tool that orchestrates common project quality checks",
  "main": "dist/cli.js",
  "type": "module",
  "bin": {
    "sncheck": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "quality",
    "check",
    "lint",
    "test",
    "format"
  ],
  "author": "VSHAL",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "listr2": "^10.2.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0"
  }
}
