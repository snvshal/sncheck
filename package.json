{
  "name": "sncheck",
  "version": "1.0.0",
  "description": "A CLI tool that orchestrates common project quality checks",
  "main": "dist/cli.js",
  "type": "module",
  "bin": {
    "sncheck": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "keywords": [
    "cli",
    "quality",
    "check",
    "lint",
    "test",
    "format"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "listr2": "^10.2.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0"
  }
}
